{
  "name": "universal-model-router",
  "version": "2.0.0",
  "description": "The ultimate AI model router - route requests between OpenAI, Anthropic, local models, and more",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "model-router": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --hot run src/server.ts",
    "dev:gui": "cd gui && bun run dev --host",
    "build:gui": "cd gui && bun run build",
    "start:all": "./start.sh",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "openai",
    "anthropic",
    "ollama",
    "llm",
    "router",
    "proxy",
    "gateway",
    "ai",
    "model"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  }
}
