{
  "name": "apibench",
  "version": "0.1.0",
  "description": "LiteLLM vs API Map vs Direct - Benchmark Suite (Bun/TypeScript benchmark runner + mock server, Python only for PDF reports)",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf logs/*.json results/*.json results/*.md reports/*.pdf",
    "report": "python3 visualize.py results/",
    "report:text": "python3 visualize.py --text-only results/",
    "stop": "docker-compose down -v"
  },
  "dependencies": {
    "elysia": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
